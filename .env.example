# ============================================================================
# GEMELO DIGITAL - Configuración de entorno
# ============================================================================
# Copia este archivo como .env y llena los valores:
#   cp .env.example .env
#
# IMPORTANTE: El archivo .env NO se sube a Git (está en .gitignore)
# ============================================================================

# ============================================================================
# PROVEEDOR Y MODELO POR DEFECTO
# Estos aplican a TODOS los agentes si no se especifica uno individual.
# Proveedores soportados: google | deepseek | anthropic | ollama
# ============================================================================
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash-lite

# ============================================================================
# MODELO POR AGENTE (opcional)
# Si quieres que un agente use un modelo diferente al default, descomenta
# las 2 lineas (PROVIDER + MODEL) del agente que quieras personalizar.
#
# Ejemplo: Generador con DeepSeek y todo lo demas con Google:
#   LLM_PROVIDER=google          <- default
#   GENERADOR_PROVIDER=deepseek  <- override solo para generador
#   GENERADOR_MODEL=deepseek-chat
# ============================================================================

# Agente de Requerimientos (analiza lo que pide el usuario)
# REQS_PROVIDER=google
# REQS_MODEL=gemini-2.5-flash-lite

# Agente Arquitecto (define la estructura de archivos del proyecto)
# ARQUITECTO_PROVIDER=google
# ARQUITECTO_MODEL=gemini-2.5-flash-lite

# Agente Generador (genera el codigo HTML, CSS, JS, Python, etc.)
# GENERADOR_PROVIDER=deepseek
# GENERADOR_MODEL=deepseek-chat

# ============================================================================
# API KEYS
# Solo necesitas poner la key del proveedor que vayas a usar.
# ============================================================================

# Google Gemini (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# DeepSeek (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=

# Anthropic Claude (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Pexels (imagenes gratuitas - https://www.pexels.com/api/new/)
PEXELS_API_KEY=

# ============================================================================
# OLLAMA (solo si usas ollama como proveedor - corre local)
# ============================================================================
OLLAMA_URL=http://localhost:11434

# ============================================================================
# DIRECTORIOS Y LOGGING
# ============================================================================
PROYECTOS_DIR=./proyectos_generados
APRENDIZAJE_DIR=./aprendizaje
LOG_LEVEL=INFO
LOG_FILE=./logs/gemelo_digital.log

# ============================================================================
# WEBHOOK EXTERNO (opcional, para integrar con N8N u otro)
# ============================================================================
N8N_WEBHOOK_URL=
